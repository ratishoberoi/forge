FORGE_ENV=development
FORGE_LOG_LEVEL=INFO
FORGE_API_HOST=0.0.0.0
FORGE_API_PORT=8000
FORGE_API_WORKERS=1
FORGE_MODEL_NAME=deepseek-ai/deepseek-coder-6.7b-instruct
FORGE_MODEL_ALIAS=deepseek-coder
FORGE_MODEL_TRUST_REMOTE_CODE=true
FORGE_MODEL_DTYPE=auto
FORGE_MODEL_MAX_MODEL_LEN=16384
FORGE_MODEL_GPU_MEMORY_UTILIZATION=0.92
FORGE_MODEL_TENSOR_PARALLEL_SIZE=1
FORGE_MODEL_MAX_NUM_SEQS=16
FORGE_MODEL_ENABLE_PREFIX_CACHING=true
FORGE_MODEL_DOWNLOAD_DIR=
FORGE_MODEL_TEMPERATURE=0.2
FORGE_MODEL_TOP_P=0.95
FORGE_MODEL_MAX_TOKENS=1024
FORGE_MODEL_ENFORCE_EAGER=false
FORGE_MODEL_QUANTIZATION=
FORGE_EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
FORGE_EMBEDDING_MODEL_ALIAS=bge-small
FORGE_EMBEDDING_BATCH_SIZE=32
FORGE_EMBEDDING_MAX_LENGTH=512
FORGE_EMBEDDING_CACHE_PATH=.forge/cache/embeddings.sqlite3
FORGE_VECTOR_DB_PATH=.forge/qdrant
FORGE_VECTOR_COLLECTION=forge_repo_chunks
FORGE_REPO_DEFAULT_ROOT=
FORGE_REPO_IGNORE_PATTERNS=.git,node_modules,.venv,dist,build,__pycache__,*.pyc
FORGE_REPO_RESPECT_GITIGNORE=true
FORGE_REPO_MAX_FILE_BYTES=524288
FORGE_REPO_INDEX_STATE_PATH=.forge/index_state.json
FORGE_REPO_INCREMENTAL=true
FORGE_REPO_RETRIEVAL_LIMIT=8
FORGE_REPO_GRAPH_NEIGHBORS=6
FORGE_REPO_WATCHER_ENABLED=false
FORGE_REPO_WATCHER_DEBOUNCE_MS=750
